# StoryForge 生产环境变量示例（复制为 .env 后填写，不要提交真实密钥）

# 必填：JWT 签名密钥（建议 ≥32 字符）
JWT_SECRET=please-change-to-a-long-random-secret

# Google OAuth（登录依赖；回调地址需登记为 http(s)://你的域名或IP:端口/api/auth/google/callback）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 对外映射端口
HOST_PORT=3000

# 是否给 Cookie 加 Secure（仅 HTTPS 时设 true；用 http://IP 访问时保持 false）
COOKIE_SECURE=false

# 可选：管理员用户 ID（逗号分隔）
# STORYFORGE_ADMIN_USER_IDS=

# 可选：国内服务器访问 Google 时的代理
# HTTPS_PROXY=
# HTTP_PROXY=
